#!/usr/bin/env bash

set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/dotfiles}"
HOST_FILE="${DOTFILES_HOST_FILE:-$DOTFILES/.config/dotfiles/host}"
HYPR_HOST_FILE="$DOTFILES/.config/hypr/host.conf"
ROFI_HOST_FILE="$DOTFILES/.config/rofi/host.rasi"
ROFI_POWERMENU_HOST_FILE="$DOTFILES/.config/rofi/powermenu/host.rasi"
WAYBAR_HOST_FILE="$DOTFILES/.config/waybar/host.css"
WAYBAR_CONFIG_FILE="$DOTFILES/.config/waybar/config.jsonc"
GHOSTTY_HOST_FILE="$DOTFILES/.config/ghostty/host"

source "$DOTFILES/shell/host.sh"

HYPR_TEMPLATE="$DOTFILES/.config/hypr/hosts/$DOTFILES_HOST.conf"
ROFI_TEMPLATE="$DOTFILES/.config/rofi/hosts/$DOTFILES_HOST.rasi"
ROFI_POWERMENU_TEMPLATE="$DOTFILES/.config/rofi/powermenu/hosts/$DOTFILES_HOST.rasi"
WAYBAR_TEMPLATE="$DOTFILES/.config/waybar/hosts/$DOTFILES_HOST.css"
WAYBAR_CONFIG_TEMPLATE="$DOTFILES/.config/waybar/hosts/$DOTFILES_HOST.jsonc"
GHOSTTY_TEMPLATE="$DOTFILES/.config/ghostty/hosts/$DOTFILES_HOST"

if [[ ! -f "$HYPR_TEMPLATE" || ! -f "$ROFI_TEMPLATE" || ! -f "$ROFI_POWERMENU_TEMPLATE" || ! -f "$WAYBAR_TEMPLATE" || ! -f "$WAYBAR_CONFIG_TEMPLATE" || ! -f "$GHOSTTY_TEMPLATE" ]]; then
  echo "Faltan overrides versionados para '$DOTFILES_HOST'"
  exit 1
fi

mkdir -p "$DOTFILES/.config/dotfiles"
mkdir -p "$DOTFILES/.config/hypr"
mkdir -p "$DOTFILES/.config/rofi"
mkdir -p "$DOTFILES/.config/rofi/powermenu"
mkdir -p "$DOTFILES/.config/waybar"
mkdir -p "$DOTFILES/.config/ghostty"

{
  printf '%s\n' '# Archivo local generado por apply-host-config'
  cat "$HYPR_TEMPLATE"
} > "$HYPR_HOST_FILE"

cat > "$ROFI_HOST_FILE" <<EOF
/* Archivo local generado por apply-host-config */
@import "~/.config/rofi/hosts/$DOTFILES_HOST.rasi"
EOF

cat > "$ROFI_POWERMENU_HOST_FILE" <<EOF
/* Archivo local generado por apply-host-config */
@import "~/.config/rofi/powermenu/hosts/$DOTFILES_HOST.rasi"
EOF

cat > "$WAYBAR_HOST_FILE" <<EOF
/* Archivo local generado por apply-host-config */
@import url("hosts/$DOTFILES_HOST.css");
EOF

if command -v jq >/dev/null 2>&1; then
  jq -s '.[0] * .[1]' \
    "$DOTFILES/.config/waybar/config.base.jsonc" \
    "$WAYBAR_CONFIG_TEMPLATE" > "$WAYBAR_CONFIG_FILE"
else
  echo "jq es requerido para generar .config/waybar/config.jsonc"
  exit 1
fi

{
  printf '%s\n' '# Archivo local generado por apply-host-config'
  cat "$GHOSTTY_TEMPLATE"
} > "$GHOSTTY_HOST_FILE"

echo "✔ Overrides locales aplicados para '$DOTFILES_HOST'"
