#!/usr/bin/env bash

set -euo pipefail

VPN_NAME="${VPN_SERVICE:-galileo}"

if [[ "$VPN_NAME" == *@* ]]; then
  SERVICE="$VPN_NAME"
else
  SERVICE="openvpn-client@$VPN_NAME"
fi

run_systemctl() {
  if ! sudo -n systemctl "$1" "$SERVICE"; then
    notify-send "VPN" "Falta permiso sudo para controlar $SERVICE"
    exit 1
  fi
}

if systemctl is-active --quiet "$SERVICE"; then
  run_systemctl stop
  notify-send "VPN" "Galileo desconectada"
else
  run_systemctl start
  notify-send "VPN" "Galileo conectada"
fi
