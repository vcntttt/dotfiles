{
  "modules-right": [
    "tray",
    "custom/projector",
    "custom/weather",
    "custom/vpn",
    "pulseaudio",
    "cpu",
    "temperature",
    "custom/gpu",
    "memory",
    "battery#bat0",
    "clock",
    "custom/notification"
  ],
  "custom/projector": {
    "exec": "$HOME/.local/bin/waybar-projector",
    "return-type": "json",
    "interval": 0,
    "signal": 8,
    "tooltip": true
  }
}
