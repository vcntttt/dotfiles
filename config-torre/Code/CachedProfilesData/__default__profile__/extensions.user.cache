e Django","original":"Run Selection/Line in Django Shell"}},{"category":"Python","command":"python.execSelectionInTerminal","title":{"value":"Ejecutar selección o línea en el terminal de Python","original":"Run Selection/Line in Python Terminal"}},{"category":"Python","command":"python.launchTensorBoard","title":{"value":"Iniciar Tensorboard","original":"Launch TensorBoard"}},{"category":"Python","command":"python.refreshTensorBoard","enablement":"python.hasActiveTensorBoardSession","icon":"$(refresh)","title":{"value":"Actualizar TensorBoard","original":"Refresh TensorBoard"}},{"category":"Python","command":"python.reportIssue","title":{"value":"Notificar problema...","original":"Report Issue..."}},{"category":"Test","command":"testing.reRunFailTests","icon":"$(run-errors)","title":{"value":"Volver a ejecutar las pruebas con errores","original":"Rerun Failed Tests"}},{"category":"Python","command":"python.setInterpreter","title":{"value":"Seleccionar intérprete","original":"Select Interpreter"}},{"category":"Python","command":"python.startREPL","title":{"value":"Iniciar REPL","original":"Start REPL"}},{"category":"Python","command":"python.viewLanguageServerOutput","enablement":"python.hasLanguageServerOutputChannel","title":{"value":"Mostrar la salida del servidor de lenguaje","original":"Show Language Server Output"}},{"category":"Python","command":"python.viewOutput","icon":{"dark":"resources/dark/repl.svg","light":"resources/light/repl.svg"},"title":{"value":"Mostrar salida","original":"Show Output"}},{"category":"Python","command":"python.installJupyter","title":{"value":"Instalar la extensión de Jupyter","original":"Install the Jupyter extension"}}],"configuration":{"properties":{"python.activeStateToolPath":{"default":"state","description":"Ruta de acceso al ejecutable de la herramienta de estado para los runtimes de ActiveState (versión 0.36+).","scope":"machine-overridable","type":"string"},"python.autoComplete.extraPaths":{"default":[],"description":"Lista de rutas de acceso a bibliotecas y similares que el motor de autocompletar debe importar. Por ejemplo, cuando se usa Google App SDK, las rutas de acceso no se encuentran en la ruta de acceso del sistema, por lo que deben agregarse a esta lista.","scope":"resource","type":"array","uniqueItems":true},"python.createEnvironment.contentButton":{"default":"show","markdownDescription":"Muestre u oculte el botón Crear entorno en el editor para \"requirements.txt\" u otros archivos de dependencia.","scope":"machine-overridable","type":"string","enum":["show","hide"],"tags":["experimental"]},"python.createEnvironment.trigger":{"default":"off","markdownDescription":"Detectar si se requiere la creación del entorno para el proyecto actual","scope":"machine-overridable","type":"string","enum":["off","prompt"],"tags":["experimental"]},"python.condaPath":{"default":"","description":"Ruta de acceso al ejecutable de conda que se va a usar para la activación (versión 4.4+).","scope":"machine","type":"string"},"python.defaultInterpreterPath":{"default":"python","markdownDescription":"Ruta de acceso predeterminada de Python que se usará cuando la extensión se cargue por primera vez, dejará de usarse una vez que se seleccione un intérprete para el área de trabajo. Consulte [aquí](https://aka.ms/AAfekmf) para comprender cuándo se usa","scope":"machine-overridable","type":"string"},"python.diagnostics.sourceMapsEnabled":{"default":false,"description":"Habilite la compatibilidad con el mapa de origen para hacer seguimientos de pila significativos en los registros de errores.","scope":"application","type":"boolean"},"python.envFile":{"default":"${workspaceFolder}/.env","description":"Ruta de acceso absoluta a un archivo que contiene definiciones de variables de entorno.","scope":"resource","type":"string"},"python.experiments.enabled":{"default":true,"description":"Habilita experimentos de pruebas A/B en la extensión de Python. Si se habilita, puede incluirse en las mejoras o características propuestas.","scope":"machine","type":"boolean"},"python.experiments.optInto":{"default":[],"markdownDescription":"Lista de experimentos de los que participar. Si está vacía, al usuario se le asignan los grupos de experimentos predeterminados. Consulte [aquí](https://github.com/microsoft/vscode-python/wiki/AB-Experiments) para obtener más información.","items":{"enum":["All","pythonSurveyNotification","pythonPromptNewToolsExt","pythonTerminalEnvVarActivation","pythonDiscoveryUsingWorkers","pythonTestAdapter","pythonREPLSmartSend","pythonRecommendTensorboardExt"],"enumDescriptions":["Lista combinada de todos los experimentos.","Denota el experimento de notificación de encuestas de Python.","Indica el experimento Python Prompt New Tools Extension.","Permite el uso de variables de entorno para activar terminales en lugar de enviar comandos de activación.","Permite el uso de subprocesos de trabajo para realizar un cálculo intensivo al detectar intérpretes.","Denota el experimento del adaptador de pruebas de Python.","Denota el experimento de envío inteligente REPL de Python.","Denota el experimento de recomendación de extensión de Tensorboard."]},"scope":"machine","type":"array","uniqueItems":true},"python.experiments.optOutFrom":{"default":[],"markdownDescription":"Lista de experimentos de los que no participar. Si está vacía, al usuario se le asignan los grupos de experimentos predeterminados. Consulte [aquí](https://github.com/microsoft/vscode-python/wiki/AB-Experiments) para obtener más información.","items":{"enum":["All","pythonSurveyNotification","pythonPromptNewToolsExt","pythonTerminalEnvVarActivation","pythonDiscoveryUsingWorkers","pythonTestAdapter","pythonREPLSmartSend"],"enumDescriptions":["Lista combinada de todos los experimentos.","Denota el experimento de notificación de encuestas de Python.","Indica el experimento Python Prompt New Tools Extension.","Permite el uso de variables de entorno para activar terminales en lugar de enviar comandos de activación.","Permite el uso de subprocesos de trabajo para realizar un cálculo intensivo al detectar intérpretes.","Denota el experimento del adaptador de pruebas de Python.","Denota el experimento de envío inteligente REPL de Python."]},"scope":"machine","type":"array","uniqueItems":true},"python.globalModuleInstallation":{"default":false,"description":"Indica si se van a instalar módulos de Python globalmente cuando no se usa un entorno.","scope":"resource","type":"boolean"},"python.languageServer":{"default":"Default","description":"Define el tipo de servidor de lenguaje.","enum":["Default","Jedi","Pylance","None"],"enumDescriptions":["Selecciona automáticamente un servidor de lenguaje: Pylance si está instalado y disponible; de lo contrario, vuelve a Jedi.","Usa Jedi detrás del Protocolo del servidor de lenguaje (LSP) como servidor de lenguaje.","Use Pylance como servidor de lenguaje.","Deshabilite las funcionalidades del servidor de lenguaje."],"scope":"window","type":"string"},"python.interpreter.infoVisibility":{"default":"onPythonRelated","description":"Controla cuándo mostrar información del intérprete seleccionado en la barra de estado.","enum":["never","onPythonRelated","always"],"enumDescriptions":["No mostrar nunca información.","Solo muestra información si se abren archivos relacionados con Python.","Mostrar siempre información."],"scope":"machine","type":"string"},"python.logging.level":{"default":"error","deprecationMessage":"Esta configuración está en desuso. Use el comando 'Developer: Set Log Level...' para establecer el nivel de registro.","description":"Nivel de registro en el que se registra la extensión; el valor predeterminado es \"error\".","enum":["debug","error","info","off","warn"],"scope":"machine","type":"string"},"python.missingPackage.severity":{"default":"Hint","description":"Establecer la gravedad de los paquetes que faltan en requirements.txt o pyproject.toml","enum":["Error","Hint","Information","Warning"],"scope":"resource","type":"string","tags":["experimental"]},"python.pipenvPath":{"default":"pipenv","description":"Ruta de acceso al ejecutable pipenv que se va a usar para la activación.","scope":"machine-overridable","type":"string"},"python.poetryPath":{"default":"poetry","description":"Ruta de acceso al ejecutable poetry.","scope":"machine-overridable","type":"string"},"python.tensorBoard.logDirectory":{"default":"","description":"Establezca esta configuración en el directorio de registro de TensorBoard que prefiera para omitir el aviso del directorio de registro al iniciar TensorBoard.","scope":"resource","type":"string","markdownDeprecationMessage":"La compatibilidad con Tensorboard se ha movido a la extensión [Extensión de Tensorboard](https://marketplace.visualstudio.com/items?itemName=ms-toolsai.tensorboard). En su lugar, use la configuración «tensorBoard.logDirectory».","deprecationMessage":"La compatibilidad con Tensorboard se ha movido a la extensión Tensorboard de la extensión. En su lugar, use la configuración «tensorBoard.logDirectory»."},"python.terminal.activateEnvInCurrentTerminal":{"default":false,"description":"Active el entorno de Python en el terminal actual al cargar la extensión.","scope":"resource","type":"boolean"},"python.terminal.activateEnvironment":{"default":true,"description":"Active el entorno de Python en todos los terminales creados.","scope":"resource","type":"boolean"},"python.terminal.executeInFileDir":{"default":false,"description":"Al ejecutar un archivo en el terminal, si se debe usar ejecutar en el directorio del archivo en lugar de en la carpeta abierta actual.","scope":"resource","type":"boolean"},"python.terminal.focusAfterLaunch":{"default":false,"description":"Al iniciar un terminal de Python, indica si se va a centrar el cursor en el terminal.","scope":"resource","type":"boolean"},"python.terminal.launchArgs":{"default":[],"description":"Argumentos de inicio de Python que se usarán al ejecutar un archivo en el terminal.","scope":"resource","type":"array"},"python.REPL.enableREPLSmartSend":{"default":true,"description":"Alterne el envío inteligente para la REPL de Python. El envío inteligente permite enviar el bloque de código más pequeño que se pueda ejecutar a REPL en Mayús+Entrar y mueve el cursor en consecuencia.","scope":"resource","type":"boolean"},"python.testing.autoTestDiscoverOnSaveEnabled":{"default":true,"description":"Habilite la detección de pruebas de ejecución automática al guardar un archivo de prueba.","scope":"resource","type":"boolean"},"python.testing.cwd":{"default":null,"description":"Directorio de trabajo opcional para pruebas.","scope":"resource","type":"string"},"python.testing.debugPort":{"default":3000,"description":"Número de puerto usado para la depuración de pruebas.","scope":"resource","type":"number"},"python.testing.promptToConfigure":{"default":true,"description":"Se le pedirá que configure un marco de pruebas si se detectan directorios de pruebas potenciales.","scope":"resource","type":"boolean"},"python.testing.pytestArgs":{"default":[],"description":"Argumentos aprobados. Cada argumento es un elemento independiente de la matriz.","items":{"type":"string"},"scope":"resource","type":"array"},"python.testing.pytestEnabled":{"default":false,"description":"Habilite las pruebas con pytest.","scope":"resource","type":"boolean"},"python.testing.pytestPath":{"default":"pytest","description":"Ruta de acceso a pytest (pytest), puede usar una versión personalizada de pytest modificando esta configuración para incluir la ruta de acceso completa.","scope":"machine-overridable","type":"string"},"python.testing.unittestArgs":{"default":["-v","-s",".","-p","*test*.py"],"description":"Argumentos aprobados. Cada argumento es un elemento independiente de la matriz.","items":{"type":"string"},"scope":"resource","type":"array"},"python.testing.unittestEnabled":{"default":false,"description":"Habilite las pruebas con unittest.","scope":"resource","type":"boolean"},"python.venvFolders":{"default"