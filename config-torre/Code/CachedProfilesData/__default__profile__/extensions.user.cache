e,"live-server-extension":false,"live-preview-extension":false},"properties":{"webpack":{"type":"boolean","description":"Webpack powered apps (such as Create React App or Angular CLI app)"},"vite":{"type":"boolean","description":"Vite powered apps"},"angular":{"type":"boolean","description":"Angular CLI powered apps"},"jest":{"type":"boolean","description":"Jest"},"cypress":{"type":"boolean","description":"Cypress.io"},"next.js":{"type":"boolean","description":"Next.js"},"nest.js":{"type":"boolean","description":"Nest.js"},"http-server":{"type":"boolean","description":"`http-server` node module"},"serve":{"type":"boolean","description":"`serve` node module"},"live-server":{"type":"boolean","description":"`live-server` node module"},"nuxt":{"type":"boolean","description":"Nuxt Vue.js"},"remix":{"type":"boolean","description":"Remix"},"qwik":{"type":"boolean","description":"Qwik"},"hydrogen":{"type":"boolean","description":"Shopify's Hydrogen"},"serverless":{"type":"boolean","description":"Serverless Offline"},"astro":{"type":"boolean","description":"Astro"},"live-server-extension":{"type":"boolean","description":"Live Server extension (restart editor after changing this setting)"},"live-preview-extension":{"type":"boolean","description":"Live Preview extension (restart editor after changing this setting)"}},"additionalProperties":false,"markdownDescription":"Tools (node modules and extensions) to automatically enable Console Ninja for."},"console-ninja.allowedHosts":{"order":1,"scope":"resource","type":"array","items":{"type":"string"},"uniqueItems":true,"markdownDescription":"The list of host names that may connect to Console Ninja. Defaults to the current machine IP addresses and host name (`localhost`, `127.0.0.1`, `example.cypress.io`, `os.hostname()`, Network Adapter IP v4 Addresses). Add additional host names if you need to connect to Console Ninja from a different/custom host name **(restart editor after changing this setting)**."},"console-ninja.showWhatsNew":{"order":2,"markdownDescription":"Display information about new features when they are released.","type":"boolean","default":true},"console-ninja.featureSet":{"order":5,"type":"string","default":"Pro","markdownDescription":"Choose whether to use Pro or Community feature set.","enum":["Pro","Community"],"enumDescriptions":["Use all Console Ninja features","Only use Console Ninja features that will be available in the free Community Edition"]},"console-ninja.installBinToPath":{"order":4,"scope":"resource","type":"boolean","default":true,"markdownDescription":"Install [bin](https://github.com/wallabyjs/console-ninja#universal-node-applications) folder to PATH."},"console-ninja.searchUrl":{"order":3,"markdownDescription":"(**PRO feature**) Template of web search URL. Use `{query}` placeholder to specify where to put the search query.","type":"string","default":"https://www.google.com/search?q={query}"},"console-ninja.syncSettings":{"order":6,"description":"Synchronize subscription details and other settings as a part of VS Code Settings Sync","type":"boolean","default":true},"console-ninja.predictiveLoggingEnabled":{"order":7,"markdownDescription":"(**PRO feature**) Enable Predictive Logging \n\n _(Always disabled for Community edition)_","type":"boolean","default":true},"console-ninja.allowConsoleLogToTriggerPredictions":{"order":8,"markdownDescription":"(**PRO feature**) Allow `console.log` to trigger predictions \n\n _(Always disabled for Community edition)_","type":"boolean","default":false}}},{"id":"log-viewer","title":"Log Viewer","order":1,"properties":{"console-ninja.outputMode":{"order":0,"markdownDescription":"Specifies how [Console Ninja Output](https://github.com/wallabyjs/console-ninja#log-viewer) is displayed.","type":"string","default":"Beside File","enum":["Beside File","In View"],"enumDescriptions":["Opens Console Ninja Output beside your current file","Opens Console Ninja Output in a separate view"]},"console-ninja.dateTimeFormat":{"order":1,"scope":"resource","type":"string","default":"HH:mm:ss.SSS","markdownDescription":"[Format string](https://day.js.org/docs/en/display/format) for displaying [log viewer](https://github.com/wallabyjs/console-ninja#log-viewer) entry date and time (**empty string** to disable date and time display)."},"console-ninja.dateTimeDisplayMode":{"order":2,"scope":"resource","enum":["Relative To Oldest","Relative To Previous","Absolute","None"],"markdownEnumDescriptions":["(**PRO feature**) Displays time relative to the oldest entry in the log viewer","(**PRO feature**) Displays time relative to the previous entry in the log viewer","Displays absolute date and time","Does not display date and time"],"default":"Absolute","markdownDescription":"Default display mode for [log viewer](https://github.com/wallabyjs/console-ninja#log-viewer) entry date and time."},"console-ninja.fontSize":{"order":3,"scope":"resource","type":"integer","default":10,"markdownDescription":"Controls the font size (in pixels) of the [Console Ninja Output](https://github.com/wallabyjs/console-ninja#log-viewer). Restart Console Output after changing this setting."},"console-ninja.autoClearLogViewerOnFileChanges":{"order":4,"scope":"resource","type":"boolean","default":true,"markdownDescription":"Clear [log viewer](https://github.com/wallabyjs/console-ninja#log-viewer) entries when any file changes (default value after editor restart)."},"console-ninja.openHttpLinksInEditor":{"order":5,"scope":"resource","type":"boolean","default":true,"markdownDescription":"Open `http`/`https` source links in editor as new file."},"console-ninja.maxLogViewerEntries":{"order":6,"scope":"resource","type":"integer","default":15000,"markdownDescription":"Maximum number of entries to display in the [log viewer](https://github.com/wallabyjs/console-ninja#log-viewer)."}}},{"id":"filtering","title":"Output Filtering","order":2,"properties":{"console-ninja.output.showErrors":{"order":1,"scope":"resource","type":"boolean","default":true,"markdownDescription":"(**PRO feature**) Capture and display errors. \n\n _(Always enabled for Community edition)_"},"console-ninja.output.showLogsOnlyFromOpenedFiles":{"order":2,"scope":"resource","type":"boolean","default":false,"markdownDescription":"(**PRO feature**) Capture and display logs only from files opened in editor. \n\n _(Always disabled for Community edition)_"},"console-ninja.output.showLogsFromMultipleRunningToolsTogether":{"order":3,"scope":"resource","type":"boolean","default":false,"markdownDescription":"(**PRO feature**) Display logs from multiple running tools together in a single list in [log viewer](https://github.com/wallabyjs/console-ninja#log-viewer). \n\n _(Always disabled for Community edition)_"},"console-ninja.output.showLogsFromLogPointsOnly":{"order":4,"scope":"resource","type":"boolean","default":false,"markdownDescription":"(**PRO feature**) Capture and display logs only from [logpoints](https://github.com/wallabyjs/console-ninja#logpoints), [function logpoints](https://github.com/wallabyjs/console-ninja#function-logpoints), [tracepoints](https://github.com/wallabyjs/console-ninja#tracepoints) and [timepoints](https://github.com/wallabyjs/console-ninja#timepoints), and do not capture `console.log`, `console.trace` and `console.time`. \n\n _(Always disabled for Community edition)_"},"console-ninja.captureFunctions":{"order":5,"scope":"resource","type":"boolean","default":false,"markdownDescription":"Include function names found inside logged objects."}}},{"id":"inline","title":"Inline Decorations","order":3,"properties":{"console-ninja.lightTheme.log.decorationAttachmentRenderOptions":{"description":"Inline log text render options for light themes.","type":"object","default":{"border":null,"borderColor":null,"fontStyle":null,"fontWeight":null,"textDecoration":null,"color":"#0000ff","backgroundColor":null,"margin":"1em","width":null,"height":null}},"console-ninja.lightTheme.error.decorationAttachmentRenderOptions":{"description":"Inline err